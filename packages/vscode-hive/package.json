{
  "name": "vscode-arkive",
  "displayName": "Arkive",
  "description": "View and review Agent Hive .hive workspaces",
  "version": "1.6.2",
  "publisher": "arkive",
  "license": "MIT WITH Commons-Clause",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/tctinh/agent-hive.git",
    "directory": "packages/vscode-hive"
  },
  "homepage": "https://github.com/tctinh/agent-hive#readme",
  "bugs": {
    "url": "https://github.com/tctinh/agent-hive/issues"
  },
  "keywords": [
    "ai",
    "arkive",
    "hive",
    "opencode",
    "planning",
    "workflow"
  ],
  "engines": {
    "vscode": "^1.64.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:hive.features",
    "onCommand:hive.refresh",
    "onCommand:hive.openFile",
    "onCommand:hive.plan.doneReview",
    "onCommand:hive.comment.create",
    "onCommand:hive.comment.reply",
    "onCommand:hive.comment.resolve",
    "onCommand:hive.comment.delete"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hive",
          "title": "Hive",
          "icon": "resources/icons/hive.svg"
        }
      ]
    },
    "views": {
      "hive": [
        {
          "id": "hive.features",
          "name": "Features"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "hive.features",
        "contents": "No Hive workspace found.\n\nCreate or open a workspace containing `.hive`, then refresh this view.\n\n[Refresh](command:hive.refresh)",
        "when": "!hive.hasHiveRoot"
      }
    ],
    "commands": [
      {
        "command": "hive.refresh",
        "title": "Hive: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "hive.openFile",
        "title": "Open File"
      },
      {
        "command": "hive.plan.doneReview",
        "title": "Done Review",
        "icon": "$(check)"
      },
      {
        "command": "hive.comment.create",
        "title": "Add Comment",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "hive.comment.reply",
        "title": "Reply",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "hive.comment.resolve",
        "title": "Resolve Thread"
      },
      {
        "command": "hive.comment.delete",
        "title": "Delete Comment"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "hive.refresh",
          "when": "view == hive.features",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "hive.openFile",
          "when": "viewItem == file"
        }
      ],
      "editor/title": [
        {
          "command": "hive.plan.doneReview",
          "when": "resourceFilename =~ /^(plan|overview)\\.md$/",
          "group": "navigation"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "hive.comment.create",
          "group": "inline",
          "when": "commentController == hive-plan-review && commentThreadIsEmpty"
        },
        {
          "command": "hive.comment.reply",
          "group": "inline",
          "when": "commentController == hive-plan-review && !commentThreadIsEmpty"
        },
        {
          "command": "hive.comment.resolve",
          "group": "inline",
          "when": "commentController == hive-plan-review && !commentThreadIsEmpty"
        }
      ],
      "comments/comment/title": [
        {
          "command": "hive.comment.delete",
          "group": "inline",
          "when": "commentController == hive-plan-review"
        }
      ]
    }
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node14 --sourcemap --define:import.meta.url=__importMetaUrl --banner:js=\"const __importMetaUrl = require('url').pathToFileURL(__filename).href;\"",
    "package": "bun run build && vsce package --no-dependencies -o vscode-arkive.vsix",
    "watch": "npm run build -- --watch",
    "build:types": "tsc --emitDeclarationOnly",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/vscode": "1.64.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "hive-core": "workspace:*"
  }
}
